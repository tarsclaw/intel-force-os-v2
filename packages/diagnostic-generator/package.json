{
  "name": "@ifos/diagnostic-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Diagnostic agent report generator — composes web-scraper + companies-house into a 12-section Markdown report for a UK recruitment firm.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": { "node": ">=20.0.0" },
  "bin": {
    "ifos-diagnostic-generate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node --import tsx/esm src/cli.ts"
  },
  "dependencies": {
    "@ifos/web-scraper": "workspace:*",
    "@ifos/companies-house": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
