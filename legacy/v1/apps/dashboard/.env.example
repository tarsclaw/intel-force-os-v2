# ─── apps/dashboard ─────────────────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit real values.

# ── Database ───────────────────────────────────────────────────────────────
# Postgres with pgvector enabled. Schemas: control + ops.
DATABASE_URL=postgres://user:pass@host:5432/intelforce

# ── Auth (Clerk) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── HR Worker (Approvals → Teams) ──────────────────────────────────────────
# Cloudflare Worker base URL. Used by /actions/approve to push approvals back to Teams.
WORKER_URL=https://intel-force-os-bot.workers.dev
PORTAL_API_KEY=shared-secret-with-worker

# ── Brain features ─────────────────────────────────────────────────────────
# Anthropic — used by /api/brain/[slug]/ask for streaming completions
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-sonnet-4-6)
ANTHROPIC_BRAIN_MODEL=claude-sonnet-4-6

# Cohere — used for embedding-based semantic search in the brain
# When unset, search degrades to substring matching (still works, just dumber)
COHERE_API_KEY=cohere-...

# Brain-build trigger. Set ONE of:
#   CF_BRAIN_QUEUE_URL — preferred (durable, retryable via Cloudflare Queues)
#   BRAIN_BUILDER_URL  — fallback (direct HTTP call to brain-builder-server)
# If neither is set, brains stay PENDING and must be built manually via CLI.
CF_BRAIN_QUEUE_URL=https://intelforce-brain-queue-consumer.workers.dev
# BRAIN_BUILDER_URL=https://intelforce-brain-builder.fly.dev
BRAIN_BUILDER_TOKEN=shared-secret-with-brain-builder-server
