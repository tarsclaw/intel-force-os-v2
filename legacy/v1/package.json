{
  "name": "intel-force-os",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler deploy --env preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/generate-icons.mjs",
    "package": "mkdir -p dist && cd teams-app && zip -r ../dist/intel-force-os-v1.0.0.zip . && cd ..",
    "tail": "wrangler tail --format pretty",
    "onboard": "tsx onboarding/new-tenant.ts --env=prod",
    "offboard": "tsx onboarding/offboard-tenant.ts --env=prod",
    "tenants": "tsx onboarding/list-tenants.ts --env=prod",
    "onboard:dev": "tsx onboarding/new-tenant.ts --env=dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "adaptivecards-templating": "^2.3.1",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250422.0",
    "@inquirer/prompts": "^7.4.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.0.0"
  }
}
