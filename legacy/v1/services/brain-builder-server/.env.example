# ─── services/brain-builder-server ─────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgres://user:pass@host:5432/intelforce

# ── Where graphify runs ──
# The Python FastAPI service that wraps the graphify CLI.
GRAPHIFY_SERVICE_URL=https://intelforce-graphify.fly.dev
# Optional bearer token if graphify-service is auth-gated
GRAPHIFY_SERVICE_TOKEN=

# ── Embeddings ──
# Cohere embed-v3 for semantic search. UK/EU residency aligns with the DPA.
COHERE_API_KEY=cohere-...
# Optional model override (default: embed-english-v3.0)
COHERE_EMBED_MODEL=embed-english-v3.0

# ── Inbound auth ──
# If set, clients must send `Authorization: Bearer <token>` to /build.
# Use the same value in dashboard's BRAIN_BUILDER_TOKEN env.
BRAIN_BUILDER_TOKEN=shared-secret

# ── Server ──
PORT=8090

# ── Dev mode ──
# When true, graphify is stubbed (returns empty graph). Useful for testing
# the wiring without a Python runtime + Anthropic spend.
GRAPHIFY_USE_STUB=false
